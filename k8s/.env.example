# Spec-007 Local Event Architecture Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# PostgreSQL Configuration
# ============================================
# This is required for the backend and event consumers

# Example for Neon PostgreSQL:
# DATABASE_URL=postgresql://user:password@host.neon.tech:5432/database?sslmode=require

DATABASE_URL=postgresql://user:password@localhost:5432/todo-db

# Alternative connection string format:
# DATABASE_URL=postgres://user:password@localhost:5432/todo-db

# ============================================
# Better Auth Configuration
# ============================================
# This is required for authentication in the backend and consumers

BETTER_AUTH_SECRET=your-secret-key-here-min-32-characters-long

# ============================================
# Minikube Configuration
# ============================================
# Adjust based on your system resources

MINIKUBE_CPUS=4
MINIKUBE_MEMORY=8192
MINIKUBE_DISK=30000

# ============================================
# Kafka Configuration
# ============================================
# These are set automatically by the Kafka cluster manifest
# Broker bootstrap address: kafka-cluster-kafka-bootstrap.kafka:9092

KAFKA_BROKERS=kafka-cluster-kafka-bootstrap.kafka:9092

# Kafka topics (created by kafka-topics.yaml)
KAFKA_TOPIC_TASK_EVENTS=task-events
KAFKA_TOPIC_REMINDERS=reminders
KAFKA_TOPIC_TASK_UPDATES=task-updates

# ============================================
# Dapr Configuration
# ============================================
# These are set automatically during Dapr installation

DAPR_PUBSUB_NAME=kafka-pubsub
DAPR_HTTP_PORT=3500
DAPR_GRPC_PORT=50001

# ============================================
# Application Configuration
# ============================================

# Logging level for all services
LOG_LEVEL=INFO

# FastAPI configuration
HOST=0.0.0.0
PORT=8000

# WebSocket configuration
WEBSOCKET_PORT=8005
WEBSOCKET_STORE=memory  # Use "redis" for Phase 7+

# Notification channels (Phase 2.7 only supports in_app)
NOTIFICATION_CHANNELS=in_app
EMAIL_SERVICE=console
PUSH_SERVICE=console

# Audit storage (Phase 2.7 only supports console)
AUDIT_STORAGE=console

# ============================================
# Node.js / Frontend Configuration
# ============================================

NODE_ENV=production
NEXT_PUBLIC_API_URL=http://backend:8000
NEXT_PUBLIC_LOG_LEVEL=info

# ============================================
# Kubernetes Configuration
# ============================================
# Context name for kubectl (set to Minikube)

KUBE_CONTEXT=minikube
KUBE_NAMESPACE=default

# ============================================
# Advanced Configuration (Optional)
# ============================================

# Database connection pool size
DB_POOL_SIZE=20
DB_POOL_RECYCLE=3600

# Query timeout (seconds)
QUERY_TIMEOUT=30

# Event publishing timeout (milliseconds)
EVENT_PUBLISH_TIMEOUT=5000

# Kafka consumer group timeouts
CONSUMER_SESSION_TIMEOUT=30000
CONSUMER_HEARTBEAT_INTERVAL=3000

# Pod resource requests/limits (adjust based on system)
# These are configured in the deployment YAMLs
BACKEND_REQUEST_CPU=500m
BACKEND_REQUEST_MEMORY=512Mi
BACKEND_LIMIT_CPU=1000m
BACKEND_LIMIT_MEMORY=1Gi

WORKER_REQUEST_CPU=250m
WORKER_REQUEST_MEMORY=256Mi
WORKER_LIMIT_CPU=500m
WORKER_LIMIT_MEMORY=512Mi

# ============================================
# Instructions
# ============================================
# 1. Fill in the required values above (DATABASE_URL and BETTER_AUTH_SECRET)
# 2. Run: source .env
# 3. Run the setup script: bash k8s/setup-all.sh
# 4. The setup script will prompt you for DATABASE_URL and BETTER_AUTH_SECRET
#    (you can paste them from this file or environment variables)
