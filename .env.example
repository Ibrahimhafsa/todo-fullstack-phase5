# Database connection string for Neon PostgreSQL
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_PdEILb2Zx6Qt@ep-late-violet-ahwgbwy0-pooler.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT signing secret - MUST match BETTER_AUTH_SECRET in frontend
# Minimum 32 characters required
BETTER_AUTH_SECRET=hafsa-todo-super-secret-key-1234567890!!

# OpenAI API Configuration (for Spec-4: AI Chatbot)
# Get API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# OpenAI model to use (e.g., gpt-4, gpt-4-turbo, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4

# Chat rate limiting: max requests per minute per user
CHAT_RATE_LIMIT=20

# OpenAI API timeout in seconds
OPENAI_TIMEOUT=30

